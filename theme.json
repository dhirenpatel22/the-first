{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"color": "#FFFFFF",
					"name": "Base",
					"slug": "base"
				},
				{
					"color": "#F7F7F5",
					"name": "Base Secondary",
					"slug": "base-2"
				},
				{
					"color": "#1A1A1A",
					"name": "Contrast",
					"slug": "contrast"
				},
				{
					"color": "#4A4A4A",
					"name": "Contrast Secondary",
					"slug": "contrast-2"
				},
				{
					"color": "#1A3353",
					"name": "Primary",
					"slug": "primary"
				},
				{
					"color": "#2A4F80",
					"name": "Primary Light",
					"slug": "primary-light"
				},
				{
					"color": "#E05D44",
					"name": "Accent",
					"slug": "accent"
				},
				{
					"color": "#FF8066",
					"name": "Accent Light",
					"slug": "accent-light"
				},
				{
					"color": "#767676",
					"name": "Muted",
					"slug": "muted"
				},
				{
					"color": "#E2E2E2",
					"name": "Border",
					"slug": "border"
				}
			],
			"gradients": [
				{
					"gradient": "linear-gradient(135deg, var(--wp--preset--color--primary) 0%, var(--wp--preset--color--primary-light) 100%)",
					"name": "Primary Gradient",
					"slug": "primary-gradient"
				},
				{
					"gradient": "linear-gradient(135deg, var(--wp--preset--color--accent) 0%, var(--wp--preset--color--accent-light) 100%)",
					"name": "Accent Gradient",
					"slug": "accent-gradient"
				},
				{
					"gradient": "linear-gradient(135deg, var(--wp--preset--color--contrast) 0%, var(--wp--preset--color--primary) 100%)",
					"name": "Dark Gradient",
					"slug": "dark-gradient"
				}
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif",
					"name": "System Sans",
					"slug": "system-sans"
				},
				{
					"fontFamily": "Georgia, 'Times New Roman', Times, serif",
					"name": "System Serif",
					"slug": "system-serif"
				},
				{
					"fontFamily": "'Courier New', Courier, 'Lucida Console', monospace",
					"name": "System Mono",
					"slug": "system-mono"
				}
			],
			"fontSizes": [
				{
					"fluid": false,
					"name": "XS",
					"size": "0.75rem",
					"slug": "xs"
				},
				{
					"fluid": false,
					"name": "SM",
					"size": "0.875rem",
					"slug": "sm"
				},
				{
					"fluid": false,
					"name": "MD",
					"size": "1rem",
					"slug": "md"
				},
				{
					"fluid": { "min": "1rem", "max": "1.125rem" },
					"name": "LG",
					"size": "1.125rem",
					"slug": "lg"
				},
				{
					"fluid": { "min": "1.125rem", "max": "1.25rem" },
					"name": "XL",
					"size": "1.25rem",
					"slug": "xl"
				},
				{
					"fluid": { "min": "1.25rem", "max": "1.5rem" },
					"name": "2XL",
					"size": "1.5rem",
					"slug": "2xl"
				},
				{
					"fluid": { "min": "1.5rem", "max": "1.875rem" },
					"name": "3XL",
					"size": "1.875rem",
					"slug": "3xl"
				},
				{
					"fluid": { "min": "1.875rem", "max": "2.25rem" },
					"name": "4XL",
					"size": "2.25rem",
					"slug": "4xl"
				},
				{
					"fluid": { "min": "2.25rem", "max": "3rem" },
					"name": "5XL",
					"size": "3rem",
					"slug": "5xl"
				},
				{
					"fluid": { "min": "3rem", "max": "4rem" },
					"name": "Huge",
					"size": "4rem",
					"slug": "huge"
				}
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{ "name": "1 — 4px",   "size": "0.25rem", "slug": "10" },
				{ "name": "2 — 8px",   "size": "0.5rem",  "slug": "20" },
				{ "name": "3 — 12px",  "size": "0.75rem", "slug": "30" },
				{ "name": "4 — 16px",  "size": "1rem",    "slug": "40" },
				{ "name": "5 — 24px",  "size": "1.5rem",  "slug": "50" },
				{ "name": "6 — 32px",  "size": "2rem",    "slug": "60" },
				{ "name": "7 — 48px",  "size": "3rem",    "slug": "70" },
				{ "name": "8 — 64px",  "size": "4rem",    "slug": "80" },
				{ "name": "9 — 96px",  "size": "6rem",    "slug": "90" },
				{ "name": "10 — 128px","size": "8rem",    "slug": "100" }
			],
			"units": ["%", "px", "em", "rem", "vh", "vw"]
		},
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{
					"name": "SM",
					"shadow": "0 1px 3px 0 rgba(0,0,0,0.08), 0 1px 2px -1px rgba(0,0,0,0.06)",
					"slug": "sm"
				},
				{
					"name": "MD",
					"shadow": "0 4px 6px -1px rgba(0,0,0,0.08), 0 2px 4px -2px rgba(0,0,0,0.06)",
					"slug": "md"
				},
				{
					"name": "LG",
					"shadow": "0 10px 15px -3px rgba(0,0,0,0.08), 0 4px 6px -4px rgba(0,0,0,0.05)",
					"slug": "lg"
				},
				{
					"name": "XL",
					"shadow": "0 20px 25px -5px rgba(0,0,0,0.08), 0 8px 10px -6px rgba(0,0,0,0.04)",
					"slug": "xl"
				}
			]
		},
		"blocks": {
			"core/button": {
				"border": { "radius": true }
			},
			"core/image": {
				"lightbox": { "allowEditing": true }
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system-sans)",
			"fontSize": "var(--wp--preset--font-size--md)",
			"lineHeight": "1.7",
			"fontWeight": "400"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--60)",
			"padding": {
				"top": "0",
				"right": "var(--wp--preset--spacing--60)",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--60)"
			}
		},
		"elements": {
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--5xl)",
					"fontWeight": "700",
					"lineHeight": "1.15",
					"letterSpacing": "-0.025em"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--4xl)",
					"fontWeight": "700",
					"lineHeight": "1.25",
					"letterSpacing": "-0.02em"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--3xl)",
					"fontWeight": "600",
					"lineHeight": "1.35"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--2xl)",
					"fontWeight": "600",
					"lineHeight": "1.4"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xl)",
					"fontWeight": "600",
					"lineHeight": "1.5"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--lg)",
					"fontWeight": "600",
					"lineHeight": "1.5"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--accent)"
					}
				}
			},
			"button": {
				"border": {
					"radius": "0.375rem"
				},
				"color": {
					"background": "var(--wp--preset--color--contrast)",
					"text": "var(--wp--preset--color--base)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "600",
					"letterSpacing": "0.01em"
				},
				"spacing": {
					"padding": {
						"top": "0.75rem",
						"right": "1.5rem",
						"bottom": "0.75rem",
						"left": "1.5rem"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--primary)"
					}
				}
			}
		},
		"blocks": {
			"core/site-title": {
				"typography": {
					"fontWeight": "700",
					"fontSize": "var(--wp--preset--font-size--xl)",
					"letterSpacing": "-0.01em"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--contrast)"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--primary)"
							}
						}
					}
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "500"
				}
			},
			"core/post-title": {
				"typography": {
					"lineHeight": "1.2"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--contrast)"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--primary)"
							}
						}
					}
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--border)"
				},
				"border": {
					"color": "var(--wp--preset--color--border)"
				}
			},
			"core/quote": {
				"border": {
					"color": "var(--wp--preset--color--primary)",
					"style": "solid",
					"width": "0"
				},
				"spacing": {
					"padding": {
						"left": "var(--wp--preset--spacing--60)"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xl)",
					"fontStyle": "italic",
					"lineHeight": "1.6"
				}
			},
			"core/code": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--system-mono)",
					"fontSize": "var(--wp--preset--font-size--sm)"
				},
				"color": {
					"background": "var(--wp--preset--color--base-2)"
				},
				"border": {
					"radius": "0.375rem"
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--50)",
						"right": "var(--wp--preset--spacing--60)",
						"bottom": "var(--wp--preset--spacing--50)",
						"left": "var(--wp--preset--spacing--60)"
					}
				}
			},
			"core/preformatted": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--system-mono)",
					"fontSize": "var(--wp--preset--font-size--sm)"
				},
				"color": {
					"background": "var(--wp--preset--color--base-2)"
				},
				"border": {
					"radius": "0.375rem"
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--50)",
						"right": "var(--wp--preset--spacing--60)",
						"bottom": "var(--wp--preset--spacing--50)",
						"left": "var(--wp--preset--spacing--60)"
					}
				}
			},
			"core/pullquote": {
				"border": {
					"color": "var(--wp--preset--color--primary)",
					"style": "solid",
					"width": "2px 0"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--2xl)",
					"fontStyle": "italic"
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--60)",
						"bottom": "var(--wp--preset--spacing--60)"
					}
				}
			},
			"core/tag-cloud": {
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--contrast)"
						}
					}
				}
			}
		}
	},
	"customTemplates": [
		{
			"name": "page-full-width",
			"postTypes": ["page"],
			"title": "Full Width Page"
		},
		{
			"name": "page-no-title",
			"postTypes": ["page", "post"],
			"title": "Page (No Title)"
		}
	],
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		},
		{
			"area": "uncategorized",
			"name": "sidebar",
			"title": "Sidebar"
		}
	]
}
